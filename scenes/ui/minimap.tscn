[ext_resource type="Script" path="res://scripts/ui/minimap.gd" id="1_minimap"]

[sub_resource type="Shader" id="Shader_brighten"]
code = "shader_type canvas_item;

uniform float brightness = 5.0;

void fragment() {
    vec4 tex_color = texture(TEXTURE, UV);
    // Multiply RGB to counteract the dark CanvasModulate of the world
    tex_color.rgb *= brightness; 
    COLOR = tex_color;
}"

